rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard_players/{document=**} {
      allow read, write: if false;
    }

    match /leaderboard_sessions/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
